# Copy this to .env and fill in real values. .env is gitignored - never commit it.
# All vars below are read fresh from the environment on every use - there is
# no DB-backed config, so changes take effect on container restart.

# --- HA access (used by test.sh and deploy.sh against the HA App) ---
HASS_URL=http://homeassistant.local:8123   # HA core, NOT :5591
HASS_TOKEN=                                # Long-lived access token
HASS_INGRESS_PATH=                         # Current Ingress path for the running App

# --- build.sh / docker-compose: image identity ---
DOCKER_IMAGE=                              # e.g. registry.example.com/you/matterregistry
MR_VERSION=                                # Image tag (e.g. 0.1.0); blank → :latest

# --- Optional: HA Matter Server WS URL ---
# Read directly on every request; no override needed under the HA App
# (defaults to ws://core-matter-server:5580/ws). Set this for standalone mode.
PYTHON_MATTER_SERVER=ws://homeassistant.local:5580/ws

# --- Optional: OpenThread Border Router REST URL ---
# Read directly on every request; no override needed under the HA App
# (defaults to http://homeassistant.local:8081). Set this for standalone mode.
OTBR_URL=http://homeassistant.local:8081

# --- Optional: Home Assistant Core URL + token ---
# Read directly on every request. Under the HA App, the Supervisor token is
# used automatically and these vars are ignored. Set both for standalone mode.
HA_CORE_URL=http://homeassistant.local:8123
HA_CORE_TOKEN=
    